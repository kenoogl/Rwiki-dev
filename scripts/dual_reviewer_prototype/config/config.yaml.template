# Config Template (dr-init bootstrap 用 雛形 / Bootstrap Template for dr-init)
# Req 2.2: dr-init が target project の `.dual-reviewer/config.yaml` に copy する placeholder。
# project bootstrap 後、user が <...> placeholder を具体 model identifier に置換する。
# 確定 timing = bootstrap 後の最初の review 起動前。

primary_model: <primary-model>           # primary reviewer 役割の concrete model identifier (例: claude-opus-4-7)
adversarial_model: <adversarial-model>   # adversarial reviewer 役割の concrete model identifier
judgment_model: <judgment-model>         # judgment reviewer 役割の concrete model identifier
lang: ja                                 # Req 2.4: default ja (Phase A scope; --lang en 等は Phase B-1.3)
dev_log_path: .dual-reviewer/dev_log.jsonl  # Req 2.2: AC1 placeholder と整合 (target project root からの相対 path)
